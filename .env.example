# LiveKit Cloud
CLOUD_URL=wss://your-project.livekit.cloud
CLOUD_API_KEY=your_livekit_api_key
CLOUD_API_SECRET=your_livekit_api_secret

# AI Providers
DEEPGRAM_API_KEY=your_deepgram_key
OPENAI_API_KEY=your_openai_key
CARTESIA_API_KEY=your_cartesia_key

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/dental_bot

# Clinic Info (optional overrides)
CLINIC_NAME=ABC Dental Clinic
CLINIC_PHONE=+1-555-000-1234
CLINIC_ADDRESS=123 Main Street, Suite 200, New York, NY 10001
CLINIC_HOURS=Monday to Friday, 9 AM to 6 PM
CLINIC_INSURANCE=Delta Dental, Cigna, Aetna, MetLife, Guardian, and most PPO plans
